{
  "name": "lpdf",
  "displayName": "Lpdf",
  "description": "VS Code extension for Lpdf — PDF as Code on every platform. You describe a document as code or XML. Lpdf renders a compact, pixel-perfect PDF — identical across platforms.",
  "license": "SEE LICENSE IN LICENSE",
  "publisher": "lpdfio",
  "version": "0.0.0",
  "preview": true,
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#141414",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lpdfio/lpdf-vscode"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18.17.1"
  },
  "extensionDependencies": [
    "redhat.vscode-xml"
  ],
  "keywords": [
    "pdf",
    "xml",
    "pdf preview",
    "pdf export",
    "pdf create",
    "pdf design",
    "document",
    "template"
  ],
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:xml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "lpdf.pdfViewer",
        "displayName": "Lpdf PDF Viewer",
        "selector": [{ "filenamePattern": "*.pdf" }],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "lpdf",
      "properties": {
        "lpdf.licenseKey": {
          "type": "string",
          "default": "",
          "description": "lpdf license key"
        },
        "lpdf.trace": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose trace logging for lpdf in the extension output channel (useful for debugging)."
        },
        "lpdf.defaultPdfViewer": {
          "type": "boolean",
          "default": false,
          "description": "Use the Lpdf viewer as the default viewer for PDF files. When enabled, clicking a .pdf file opens it in the Lpdf PDF viewer instead of VS Code's default binary viewer."
        }
      }
    },
    "commands": [
      { "command": "lpdf.openPdf",        "title": "Lpdf: View PDF" },
      { "command": "lpdf.previewPdf",     "title": "Lpdf: Preview PDF" },
      { "command": "lpdf.exportPdf",      "title": "Lpdf: Export PDF"  },
      { "command": "lpdf.generateHere",   "title": "Lpdf: Generate Code" },
      { "command": "lpdf.linkDataFile",   "title": "Lpdf: Link Data File..."  },
      { "command": "lpdf.unlinkDataFile", "title": "Lpdf: Unlink Data File"   },
      { "command": "lpdf.generateTs",     "title": "Lpdf: Generate TypeScript from XML" },
      { "command": "lpdf.generateCs",     "title": "Lpdf: Generate C# from XML" },
      { "command": "lpdf.generatePy",     "title": "Lpdf: Generate Python from XML" },
      { "command": "lpdf.generatePhp",    "title": "Lpdf: Generate PHP from XML" }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .pdf",
          "command": "lpdf.openPdf",
          "group": "2_z_lpdf@1"
        },
        {
          "when": "resourceFilename =~ /\\.lpdf\\.xml$/",
          "command": "lpdf.previewPdf",
          "group": "2_z_lpdf@1"
        },
        {
          "when": "resourceFilename =~ /\\.lpdf\\.xml$/",
          "command": "lpdf.exportPdf",
          "group": "2_z_lpdf@2"
        },
        {
          "when": "resourceFilename =~ /\\.lpdf\\.xml$/",
          "command": "lpdf.generateHere",
          "group": "2_z_lpdf@3"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.0.0",
    "pdfjs-dist": "^5.6.205",
    "typescript": "^5.0.0"
  }
}
