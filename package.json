{
  "name": "lpdf",
  "displayName": "LPDF (Preview)",
  "description": "VS Code extension for lpdf — pixel-perfect, lightweight, and consistent PDF rendering",
  "license": "SEE LICENSE IN LICENSE",
  "publisher": "lpdfio",
  "version": "0.5.2",
  "preview": true,
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/lpdfio/lpdf-vscode"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18.17.1"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:xml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "lpdf",
      "properties": {
        "lpdf.licenseKey": {
          "type": "string",
          "default": "",
          "description": "lpdf license key"
        },
        "lpdf.trace": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose trace logging for lpdf in the extension output channel (useful for debugging)."
        }
      }
    },
    "commands": [
      { "command": "lpdf.previewPdf", "title": "LPDF: Preview PDF" },
      { "command": "lpdf.exportPdf",  "title": "LPDF: Export PDF"  },
      { "command": "lpdf.generateTs",  "title": "LPDF: Generate TypeScript from XML" },
      { "command": "lpdf.generateCs",  "title": "LPDF: Generate C# from XML" },
      { "command": "lpdf.generatePy",  "title": "LPDF: Generate Python from XML" },
      { "command": "lpdf.generatePhp", "title": "LPDF: Generate PHP from XML" },
      { "command": "lpdf.generateHere","title": "LPDF: Generate lpdf code here" }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .xml",
          "command": "lpdf.previewPdf",
          "group": "navigation@1"
        },
        {
          "when": "resourceExtname == .xml",
          "command": "lpdf.exportPdf",
          "group": "navigation@2"
        },
        {
          "when": "resourceExtname == .xml",
          "command": "lpdf.generateHere",
          "group": "navigation@3"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.0.0",
    "pdfjs-dist": "^5.6.205",
    "typescript": "^5.0.0"
  }
}
