{
  "name": "lpdf",
  "displayName": "Lpdf",
  "description": "VS Code extension for Lpdf — PDF as Code, on every platform. Describe your document structure in code using the programming Kit, or XML. Every PDF is compact, pixel-perfect, and identical across platforms.",
  "license": "SEE LICENSE IN LICENSE",
  "publisher": "lpdfio",
  "version": "0.0.0",
  "preview": true,
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#141414",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lpdfio/lpdf-vscode"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18.17.1"
  },
  "extensionDependencies": [
    "redhat.vscode-xml"
  ],
  "keywords": [
    "pdf",
    "xml",
    "pdf preview",
    "pdf export",
    "pdf create",
    "pdf design",
    "document",
    "template"
  ],
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:xml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "lpdf.pdfViewer",
        "displayName": "Lpdf PDF Viewer",
        "selector": [{ "filenamePattern": "*.pdf" }],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "lpdf",
      "properties": {
        "lpdf.licenseKey": {
          "type": "string",
          "default": "",
          "description": "lpdf license key"
        },
        "lpdf.trace": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose trace logging for lpdf in the extension output channel (useful for debugging)."
        }
      }
    },
    "commands": [
      { "command": "lpdf.previewPdf",     "title": "Lpdf: Preview PDF" },
      { "command": "lpdf.exportPdf",       "title": "Lpdf: Export PDF"  },
      { "command": "lpdf.linkDataFile",    "title": "Lpdf: Link Data File..."  },
      { "command": "lpdf.unlinkDataFile",  "title": "Lpdf: Unlink Data File"   },
      { "command": "lpdf.generateTs",  "title": "Lpdf: Generate TypeScript from XML" },
      { "command": "lpdf.generateCs",  "title": "Lpdf: Generate C# from XML" },
      { "command": "lpdf.generatePy",  "title": "Lpdf: Generate Python from XML" },
      { "command": "lpdf.generatePhp", "title": "Lpdf: Generate PHP from XML" },
      { "command": "lpdf.generateHere","title": "Lpdf: Generate lpdf code here" },
      { "command": "lpdf.openPdf",       "title": "Lpdf: Open PDF" }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .pdf",
          "command": "lpdf.openPdf",
          "group": "navigation@1"
        },
        {
          "when": "resourceExtname == .xml",
          "command": "lpdf.previewPdf",
          "group": "navigation@1"
        },
        {
          "when": "resourceExtname == .xml",
          "command": "lpdf.exportPdf",
          "group": "navigation@2"
        },
        {
          "when": "resourceExtname == .xml",
          "command": "lpdf.generateHere",
          "group": "navigation@3"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.0.0",
    "pdfjs-dist": "^5.6.205",
    "typescript": "^5.0.0"
  }
}
